# Copy to .env and fill in. The standalone server reads these at startup.

# HTTP port for the relay server.
PORT=8080

# Per-user daily turn cap (0 = unlimited). A "turn" is one fresh user message;
# tool-result continuations and failovers do not count again.
DAILY_CAP=0

# Primary provider (required) and optional comma-separated failover chain.
# Built-in names: openai, openrouter, groq, cerebras, gemini, together,
# fireworks, deepseek, mistral. Any other name (e.g. local) works too, as long
# as you also set <NAME>_BASE_URL to an OpenAI-compatible endpoint.
PROVIDER=groq
FALLBACK=openrouter,gemini

# Per-provider credentials. For provider NAME, set NAME_API_KEY and NAME_MODEL
# (and NAME_BASE_URL for providers that are not built in). Only the providers in
# PROVIDER/FALLBACK are used; the rest are here for convenience.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# Example of a custom OpenAI-compatible upstream (e.g. a local vLLM/Ollama):
# PROVIDER=local
# LOCAL_BASE_URL=http://localhost:11434/v1/chat/completions
# LOCAL_API_KEY=ollama
# LOCAL_MODEL=llama3.1

# OpenRouter-only: request the no-data-collection routing hint. Leave false for
# OpenRouter ":free" models (they require data collection). Cerebras/Groq never
# train on API data, so this is a no-op for them.
NO_TRAIN=false

# Optional dashboard attribution headers (OpenRouter shows these).
ATTRIBUTION_REFERER=
ATTRIBUTION_TITLE=
